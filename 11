<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>生日快乐</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    min-height: 100vh;
    background: linear-gradient(135deg, #1a1a2e, #16213e, #0f3460, #53354a);
    background-size: 400% 400%;
    animation: bgShift 12s ease infinite;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: -apple-system, "PingFang SC", "Microsoft YaHei", sans-serif;
    overflow-x: hidden;
    overflow-y: auto;
  }

  @keyframes bgShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  /* ---- particles ---- */
  .particles {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
  }
  .particle {
    position: absolute;
    border-radius: 50%;
    animation: floatUp linear infinite;
    opacity: 0;
  }
  @keyframes floatUp {
    0%   { transform: translateY(100vh) scale(0); opacity: 0; }
    10%  { opacity: 1; }
    90%  { opacity: 1; }
    100% { transform: translateY(-10vh) scale(1.4); opacity: 0; }
  }

  /* ---- card ---- */
  .card {
    position: relative; z-index: 1;
    background: rgba(255,255,255,0.08);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-radius: 24px;
    border: 1px solid rgba(255,255,255,0.15);
    padding: 40px 32px;
    max-width: 380px; width: 90vw;
    text-align: center;
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
    animation: cardIn 1s ease-out;
  }
  @keyframes cardIn {
    from { transform: translateY(40px) scale(0.92); opacity: 0; }
    to   { transform: translateY(0) scale(1); opacity: 1; }
  }

  .cake {
    font-size: 80px;
    animation: bounce 1.2s ease-in-out infinite;
    display: block;
    line-height: 1;
  }
  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  .title {
    margin-top: 12px;
    font-size: 28px;
    font-weight: 700;
    line-height: 1.4;
    background: linear-gradient(90deg, #f9d423, #ff4e50, #f9d423);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 2s linear infinite;
  }
  @keyframes shimmer {
    to { background-position: 200% center; }
  }

  .subtitle {
    color: rgba(255,255,255,0.7);
    font-size: 16px;
    margin-top: 6px;
    letter-spacing: 2px;
  }

  .divider {
    width: 60px; height: 2px;
    background: linear-gradient(90deg, transparent, #f9d423, transparent);
    margin: 20px auto;
    border-radius: 1px;
  }

  .wish {
    color: rgba(255,255,255,0.9);
    font-size: 17px;
    line-height: 1.8;
    margin-bottom: 8px;
  }

  .wish p { margin: 4px 0; animation: fadeSlide 0.8s ease both; }
  .wish p:nth-child(1) { animation-delay: 0.3s; }
  .wish p:nth-child(2) { animation-delay: 0.5s; }
  .wish p:nth-child(3) { animation-delay: 0.7s; }
  .wish p:nth-child(4) { animation-delay: 0.9s; }

  @keyframes fadeSlide {
    from { transform: translateY(12px); opacity: 0; }
    to   { transform: translateY(0); opacity: 1; }
  }

  .from {
    margin-top: 24px;
    color: rgba(255,255,255,0.5);
    font-size: 14px;
    font-style: italic;
  }

  /* ---- candles ---- */
  .candles {
    display: flex; justify-content: center; gap: 16px; margin-top: 10px;
  }
  .candle {
    position: relative;
    width: 14px; height: 36px;
    background: linear-gradient(180deg, #fff7e6, #f5d6a0);
    border-radius: 4px 4px 8px 8px;
    box-shadow: inset 0 -4px 8px rgba(0,0,0,0.1);
  }
  .candle::after {
    content: '';
    position: absolute;
    top: -14px; left: 50%; transform: translateX(-50%);
    width: 8px; height: 16px;
    background: linear-gradient(180deg, #ff9a3c, #ff6f3c);
    border-radius: 50% 50% 20% 20%;
    animation: flicker 0.6s ease-in-out infinite alternate;
  }
  .candle:nth-child(2)::after { animation-delay: 0.15s; }
  .candle:nth-child(3)::after { animation-delay: 0.3s; }
  @keyframes flicker {
    from { transform: translateX(-50%) scaleY(1) scaleX(1); }
    to   { transform: translateX(-50%) scaleY(0.8) scaleX(0.7); }
  }

  /* ---- confetti ---- */
  .confetti-container {
    position: fixed; inset: 0; pointer-events: none; z-index: 0;
  }
  .confetti {
    position: absolute; top: -20px;
    width: 12px; height: 12px;
    animation: confettiFall linear forwards;
  }
  @keyframes confettiFall {
    0%   { transform: translateY(0) rotate(0deg) scale(1); opacity: 1; }
    80%  { opacity: 1; }
    100% { transform: translateY(105vh) rotate(720deg) scale(0.3); opacity: 0; }
  }

  /* ---- tap hint ---- */
  .tap-hint {
    margin-top: 28px;
    color: rgba(255,255,255,0.3);
    font-size: 12px;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.7; }
  }
</style>
</head>
<body>

<div class="particles" id="particles"></div>
<div class="confetti-container" id="confetti"></div>

<div class="card">
  <span class="cake">🎂</span>
  <div class="title">赵羽晨同学<br>生日快乐</div>
  <div class="subtitle">HAPPY BIRTHDAY</div>

  <div class="candles">
    <div class="candle"></div>
    <div class="candle"></div>
    <div class="candle"></div>
  </div>

  <div class="divider"></div>

  <div class="wish">
    <p>🎂 新的一岁，万事胜意 🎂</p>
    <p>✨ 岁岁常欢愉，年年皆胜意 ✨</p>
  </div>

  <div class="from">— 点击屏幕有惊喜 —</div>
</div>

<script>
  // ---- particles ----
  const colors = ['#f9d423','#ff4e50','#ff9a3c','#a29bfe','#fd79a8','#00cec9','#fab1a0'];
  const particlesEl = document.getElementById('particles');
  for (let i = 0; i < 40; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    const size = Math.random() * 8 + 4;
    p.style.cssText = `
      left: ${Math.random() * 100}%;
      width: ${size}px; height: ${size}px;
      background: ${colors[Math.floor(Math.random() * colors.length)]};
      animation-duration: ${Math.random() * 8 + 6}s;
      animation-delay: ${Math.random() * 6}s;
    `;
    particlesEl.appendChild(p);
  }

  // ---- confetti burst on tap ----
  const confettiEl = document.getElementById('confetti');
  function burst(x, y) {
    const shapes = ['circle','square','triangle'];
    for (let i = 0; i < 50; i++) {
      const el = document.createElement('div');
      el.className = 'confetti';
      const size = Math.random() * 10 + 6;
      const color = colors[Math.floor(Math.random() * colors.length)];
      el.style.cssText = `
        left: ${x}px;
        width: ${size}px; height: ${size}px;
        background: ${color};
        border-radius: ${shapes[Math.floor(Math.random() * 3)] === 'circle' ? '50%' : shapes[Math.floor(Math.random() * 3)] === 'triangle' ? '0' : '3px'};
        clip-path: ${shapes[Math.floor(Math.random() * 3)] === 'triangle' ? 'polygon(50% 0%, 0% 100%, 100% 100%)' : 'none'};
        animation-duration: ${Math.random() * 2 + 2}s;
        transform: translateX(${(Math.random() - 0.5) * 200}px);
      `;
      confettiEl.appendChild(el);
      el.addEventListener('animationend', () => el.remove());
    }
  }

  document.addEventListener('click', (e) => {
    burst(e.clientX || window.innerWidth / 2, e.clientY || window.innerHeight / 2);
  });
  document.addEventListener('touchstart', (e) => {
    const t = e.touches[0];
    burst(t.clientX, t.clientY);
  }, { passive: true });

  // Auto burst on load
  setTimeout(() => burst(window.innerWidth / 2, window.innerHeight / 3), 600);
</script>
</body>
</html>
